# Copy to `.env` and adjust for your host:
#   cp .env.example .env
#
# Docker Compose loads this file automatically for variable substitution.
# ssi-indexer and ssi-chat also read it via pydantic-settings (repo root or service `.env`).

# ── Vertex AI (ssi-indexer embeddings + ssi-chat Gemini) ─────────────────────
# Project *display name* is "rag-demos"; SDK and gcloud require the project *ID*:
GCP_PROJECT_ID=rag-demos-501323
GCP_REGION=us-central1
VERTEX_EMBEDDING_MODEL=text-embedding-004
VERTEX_GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_DIMENSION=768

# Docker Compose mount for ssi-indexer and ssi-chat (host path to service account key):
GCP_SA_KEY_PATH=/Users/you/.config/gcloud/rag-demos-501323-vertex-client-key.json

# Local / non-Docker runs:
GOOGLE_APPLICATION_CREDENTIALS=/Users/you/.config/gcloud/rag-demos-501323-vertex-client-key.json

# One-time GCP setup (owner account):
#   gcloud config set project rag-demos-501323
#   gcloud services enable aiplatform.googleapis.com
#   gcloud iam service-accounts create vertex-client --display-name="Vertex AI client"
#   gcloud projects add-iam-policy-binding rag-demos-501323 \
#     --member="serviceAccount:vertex-client@rag-demos-501323.iam.gserviceaccount.com" \
#     --role="roles/aiplatform.user"
#   gcloud projects add-iam-policy-binding rag-demos-501323 \
#     --member="serviceAccount:vertex-client@rag-demos-501323.iam.gserviceaccount.com" \
#     --role="roles/serviceusage.serviceUsageConsumer"
#   gcloud iam service-accounts keys create ~/.config/gcloud/rag-demos-501323-vertex-client-key.json \
#     --iam-account=vertex-client@rag-demos-501323.iam.gserviceaccount.com
# Smoke test: python scripts/vertex_smoke_test.py

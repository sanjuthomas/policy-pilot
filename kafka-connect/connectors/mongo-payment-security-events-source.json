{
  "name": "mongo-payment-security-events-source",
  "config": {
    "connector.class": "com.mongodb.kafka.connect.MongoSourceConnector",
    "tasks.max": "1",
    "connection.uri": "mongodb://mongodb:27017/?replicaSet=rs0",
    "database": "security_events",
    "collection": "payment_service",
    "topic.namespace.map": "{\"security_events.payment_service\": \"payment_security_events\"}",
    "publish.full.document.only": "true",
    "copy.existing": "true",
    "output.format.key": "json",
    "output.format.value": "json",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "value.converter": "org.apache.kafka.connect.storage.StringConverter"
  }
}

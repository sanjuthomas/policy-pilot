{
  "uid": "policy-pilot-slo-overview",
  "title": "Policy Pilot SLO Overview",
  "tags": ["policy-pilot", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "slo",
        "label": "SLO",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(slo:sli_error:ratio_rate5m, sloth_id)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "SLI error ratio (5m) by SLO",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "slo:sli_error:ratio_rate5m{sloth_id=~\"$slo\"}",
          "legendFormat": "{{sloth_id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Current burn rate vs budget",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "slo:current_burn_rate:ratio{sloth_id=~\"$slo\"}",
          "legendFormat": "{{sloth_id}}"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Error budget remaining (30d)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        {
          "refId": "A",
          "expr": "slo:period_error_budget_remaining:ratio{sloth_id=~\"$slo\"}",
          "legendFormat": "{{sloth_id}}"
        }
      ]
    }
  ]
}

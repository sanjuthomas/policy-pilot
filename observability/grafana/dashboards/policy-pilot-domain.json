{
  "uid": "policy-pilot-domain",
  "title": "Policy Pilot Domain SLIs",
  "tags": ["policy-pilot", "chat", "authz", "pipeline"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "row",
      "title": "Chat",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Chat answers by retrieval strategy (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (chat_retrieval_strategy) (rate(chat_answer_count[5m]))",
          "legendFormat": "{{chat_retrieval_strategy}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Chat generation latency p95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(chat_answer_generation_duration_bucket[5m])))",
          "legendFormat": "generation p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(chat_answer_retrieval_duration_bucket[5m])))",
          "legendFormat": "retrieval p95"
        }
      ]
    },
    {
      "type": "row",
      "title": "Feedback",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "stat",
      "title": "Non-downvote rate (5m)",
      "description": "Primary quality SLO signal: good = completed answers minus explicit downvotes. Upvotes and no-votes are both good.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.98 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min((sum(rate(chat_answer_count[5m])) - (sum(rate(chat_feedback_count{chat_feedback_rating=\"down\"}[5m])) or vector(0))) / clamp_min(sum(rate(chat_answer_count[5m])), 1), 0)",
          "legendFormat": "non-downvote"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Vote / no-vote mix (req/s)",
      "description": "No-vote is approximated as completed answers minus recorded up/down feedback.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (chat_feedback_rating) (rate(chat_feedback_count[5m]))",
          "legendFormat": "{{chat_feedback_rating}}"
        },
        {
          "refId": "B",
          "expr": "clamp_min(sum(rate(chat_answer_count[5m])) - (sum(rate(chat_feedback_count[5m])) or vector(0)), 0)",
          "legendFormat": "no_vote"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Upvote share among voters (5m)",
      "description": "Diagnostic only. This ignores silence and should not be used as the primary SLO.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(chat_feedback_count{chat_feedback_rating=\"up\"}[5m])) or vector(0)) / clamp_min(sum(rate(chat_feedback_count[5m])), 1)",
          "legendFormat": "voter satisfaction"
        }
      ]
    },
    {
      "type": "row",
      "title": "Authorization",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "type": "timeseries",
      "title": "OPA decisions by outcome (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (authz_decision) (rate(authz_evaluate_count[5m]))",
          "legendFormat": "{{authz_decision}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Deny rate (5m)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(authz_evaluate_count{authz_decision=\"deny\"}[5m])) / clamp_min(sum(rate(authz_evaluate_count[5m])), 1)",
          "legendFormat": "deny rate"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "OPA evaluate latency p95 (ms)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(authz_evaluate_duration_bucket[5m])))",
          "legendFormat": "evaluate p95"
        }
      ]
    },
    {
      "type": "row",
      "title": "Skills & pipeline",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "type": "timeseries",
      "title": "Skill funnel by outcome (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (chat_skill, chat_skill_outcome) (rate(chat_skill_outcome_count[5m]))",
          "legendFormat": "{{chat_skill}} · {{chat_skill_outcome}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Indexer consumer throughput (rec/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "cps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(etl_consumer_processed[5m]))",
          "legendFormat": "processed"
        },
        {
          "refId": "B",
          "expr": "sum(rate(etl_consumer_failed[5m]))",
          "legendFormat": "failed"
        },
        {
          "refId": "C",
          "expr": "sum(rate(etl_dlq_quarantined[5m]))",
          "legendFormat": "dlq quarantined"
        }
      ]
    }
  ]
}
